generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// EMPRESA / CONFIGURACIÓN
// ─────────────────────────────────────────────────────────────

model Empresa {
  id                String   @id @default("default")
  nombre            String   @default("Mi Empresa")
  direccion         String?
  telefono          String?
  email             String?
  
  // Horarios
  horaEntrada       String   @default("09:00")
  horaSalida        String   @default("18:00")
  toleranciaMinutos Int      @default(15)
  
  // Notificaciones
  notifEmail        Boolean  @default(true)
  notifTelegram     Boolean  @default(false)
  notifWhatsapp     Boolean  @default(false)
  emailAdmin        String?
  telegramBotToken  String?
  telegramChatId    String?
  
  // Google Sheets
  googleSheetsId    String?
  googleSheetsRange String?  @default("Registros!A:L")
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// EMPLEADOS
// ─────────────────────────────────────────────────────────────

model Empleado {
  id            String   @id @default(uuid())
  codigo        String   @unique
  nombre        String
  apellido      String
  email         String?
  telefono      String?
  puesto        String?
  departamento  String?
  fotoUrl       String?
  
  // Horario personal (opcional)
  horaEntrada   String?
  horaSalida    String?
  
  // QR
  qrCodigo      String   @unique
  qrUrl         String?
  
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relaciones
  registros     Registro[]
}

// ─────────────────────────────────────────────────────────────
// REGISTROS DE ASISTENCIA
// ─────────────────────────────────────────────────────────────

model Registro {
  id              String   @id @default(uuid())
  empleadoId      String
  empleado        Empleado @relation(fields: [empleadoId], references: [id])
  
  tipo            String   // ENTRADA, SALIDA
  fecha           String   // YYYY-MM-DD
  hora            String   // HH:MM:SS
  timestamp       DateTime @default(now())
  
  // Estado
  estado          String   @default("normal") // normal, tarde, temprano
  minutosRetraso  Int      @default(0)
  
  // Ubicación (opcional)
  latitud         Float?
  longitud        Float?
  
  // Notas
  notas           String?
  
  // Horas calculadas
  horasTrabajadas Float?
  
  // Sincronización
  syncSheets      Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  
  @@unique([empleadoId, fecha, tipo])
  @@index([fecha])
  @@index([empleadoId])
}

// ─────────────────────────────────────────────────────────────
// RESUMEN DIARIO
// ─────────────────────────────────────────────────────────────

model ResumenDiario {
  id                  String   @id @default(uuid())
  fecha               String   @unique
  empleadoId          String
  
  horaEntrada         String?
  horaSalida          String?
  horasTrabajadas     Float?
  llegoTarde          Boolean  @default(false)
  minutosRetraso      Int      @default(0)
  falta               Boolean  @default(false)
  
  createdAt           DateTime @default(now())
  
  @@unique([fecha, empleadoId])
}

// ─────────────────────────────────────────────────────────────
// NOTIFICACIONES
// ─────────────────────────────────────────────────────────────

model Notificacion {
  id            String   @id @default(uuid())
  tipo          String   // EMAIL, TELEGRAM, WHATSAPP
  destino       String
  asunto        String?
  mensaje       String
  enviado       Boolean  @default(false)
  error         String?
  createdAt     DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// MODELOS PARA SISTEMA POS
// ─────────────────────────────────────────────────────────────

model ClientePOS {
  id                String   @id @default(uuid())
  nombre            String
  email             String
  telefono          String?
  direccion         String?
  rfc               String?
  notas             String?
  comprasTotal      Int      @default(0)
  ultimaCompra      DateTime?
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([email])
}

model ProductoPOS {
  id                String   @id @default(uuid())
  codigo            String   @unique
  nombre            String
  descripcion       String?
  categoria         String   @default("General")
  stock             Int      @default(0)
  stockMinimo       Int      @default(5)
  precioCompra      Float    @default(0)
  precioVenta       Float    @default(0)
  proveedor         String?
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model VentaPOS {
  id                String   @id @default(uuid())
  numeroVenta       String   @unique
  clienteId         String?
  clienteNombre     String?
  subtotal          Float    @default(0)
  impuestos         Float    @default(0)
  descuento         Float    @default(0)
  total             Float    @default(0)
  metodoPago        String   @default("Efectivo")
  estado            String   @default("Completada")
  createdAt         DateTime @default(now())

  detalles          DetalleVentaPOS[]
}

model DetalleVentaPOS {
  id                String   @id @default(uuid())
  ventaId           String
  venta             VentaPOS @relation(fields: [ventaId], references: [id])
  productoId        String?
  productoNombre    String
  cantidad          Int
  precioUnitario    Float
  subtotal          Float
}

model ProveedorPOS {
  id                String   @id @default(uuid())
  nombre            String
  contacto          String?
  email             String?
  telefono          String?
  direccion         String?
  productos         String?
  notas             String?
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CompraPOS {
  id                String   @id @default(uuid())
  numeroCompra      String   @unique
  proveedorId       String?
  proveedorNombre   String?
  subtotal          Float    @default(0)
  impuestos         Float    @default(0)
  total             Float    @default(0)
  estado            String   @default("Pendiente")
  fecha             DateTime @default(now())
  createdAt         DateTime @default(now())

  detalles          DetalleCompraPOS[]
}

model DetalleCompraPOS {
  id                String   @id @default(uuid())
  compraId          String
  compra            CompraPOS @relation(fields: [compraId], references: [id])
  productoId        String?
  productoNombre    String
  cantidad          Int
  precioUnitario    Float
  subtotal          Float
}

model GastoPOS {
  id                String   @id @default(uuid())
  concepto          String
  categoria         String   @default("Operativo")
  monto             Float    @default(0)
  descripcion       String?
  fecha             DateTime @default(now())
  createdAt         DateTime @default(now())
}

model UsuarioPOS {
  id                String   @id @default(uuid())
  nombre            String
  email             String   @unique
  password          String?
  rol               String   @default("vendedor")
  activo            Boolean  @default(true)
  ultimoAcceso      DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ConfigPOS {
  id                String   @id @default("default")
  nombreNegocio     String   @default("Mi Negocio")
  moneda            String   @default("$")
  impuesto          Float    @default(16)
  direccion         String?
  telefono          String?
  email             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// SISTEMA DE ASISTENCIA ESCOLAR CON QR
// ─────────────────────────────────────────────────────────────

model Estudiante {
  id                String   @id @default(uuid())
  matricula         String   @unique
  nombre            String
  apellido          String
  email             String   @unique
  telefono          String?
  grupo             String?
  fotoUrl           String?
  
  // Contactos de emergencia / padres
  nombrePadre       String?
  emailPadre        String?
  telefonoPadre     String?
  telegramPadre     String?  // Username de Telegram del padre
  telegramChatIdPadre String? // Chat ID de Telegram del padre (para enviar mensajes directos)
  padreVinculado    Boolean  @default(false) // Si el padre ya se vinculó con el bot
  
  nombreMadre       String?
  emailMadre        String?
  telefonoMadre     String?
  telegramMadre     String?  // Username de Telegram de la madre
  telegramChatIdMadre String? // Chat ID de Telegram de la madre
  madreVinculada    Boolean  @default(false) // Si la madre ya se vinculó con el bot
  
  // QR único del estudiante
  qrToken           String   @unique
  qrUrl             String?
  
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relaciones
  asistencias       AsistenciaEstudiante[]
  notificaciones    NotificacionAsistencia[]
}

// Padre vinculado con Telegram
model PadreTelegram {
  id                String   @id @default(uuid())
  chatId            String   @unique  // Chat ID de Telegram
  telegramUsername  String?  // @username del padre
  nombre            String?  // Nombre del padre
  email             String?  // Email del padre
  telefono          String?  // Teléfono del padre
  
  // Código de vinculación
  codigoVinculacion String?  @unique // Código para vincular con estudiante
  codigoUsado       Boolean  @default(false)
  codigoExpira      DateTime?
  
  // Relación con estudiantes (puede tener varios hijos)
  estudiantes       String?  // IDs de estudiantes separados por coma
  
  verificado        Boolean  @default(false)
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([chatId])
  @@index([email])
}

model Clase {
  id                String   @id @default(uuid())
  codigo            String   @unique
  nombre            String
  descripcion       String?
  profesor          String?
  salon             String?
  
  // Horario
  diaSemana         Int      // 1=Lunes, 7=Domingo
  horaInicio        String   // "09:00"
  horaFin           String   // "11:00"
  
  // Configuración de asistencia
  toleranciaMinutos Int      @default(5)
  
  activa            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relaciones
  asistencias       AsistenciaEstudiante[]
}

model AsistenciaEstudiante {
  id                String   @id @default(uuid())
  estudianteId      String
  estudiante        Estudiante @relation(fields: [estudianteId], references: [id])
  
  claseId           String
  clase             Clase @relation(fields: [claseId], references: [id])
  
  fecha             String   // YYYY-MM-DD
  horaRegistro      String   // HH:MM:SS
  timestamp         DateTime @default(now())
  
  // Estado: PRESENTE, RETARDO, AUSENTE
  estado            String   @default("PRESENTE")
  minutosRetraso    Int      @default(0)
  
  // Información adicional
  dispositivo       String?
  ipRegistro        String?
  notas             String?
  
  createdAt         DateTime @default(now())
  
  @@unique([estudianteId, claseId, fecha])
  @@index([fecha])
  @@index([claseId])
}

model ConfigAsistencia {
  id                    String   @id @default("default")
  nombreInstitucion     String   @default("Instituto Educativo")
  logo                  String?
  
  // Configuración general
  horaInicioGeneral     String   @default("08:00")
  toleranciaMinutos     Int      @default(5)
  diasClase             String   @default("1,2,3,4,5") // Lunes a Viernes
  
  // Notificaciones Email
  enviarNotificaciones  Boolean  @default(true)
  emailAdmin            String?
  emailRemitente        String?  // Email desde donde se envían
  nombreRemitente       String?  @default("Sistema de Asistencia")
  
  // Notificaciones Telegram - Bot para padres
  telegramBotToken      String?  // Token del bot de Telegram
  telegramBotUsername   String?  // @username del bot
  telegramChatId        String?  // Chat ID del grupo/canal (opcional, para administradores)
  enviarTelegram        Boolean  @default(false)
  enviarTelegramPadres  Boolean  @default(true)  // Enviar a padres directamente
  telegramWebhookUrl    String?  // URL del webhook (se configura automáticamente)
  
  // Configuración de qué notificar
  notificarRetardo      Boolean  @default(true)
  notificarAusencia     Boolean  @default(true)
  notificarEntrada      Boolean  @default(false)
  
  // Personalización
  colorPrimario         String   @default("#10b981")
  mensajeBienvenida     String   @default("¡Bienvenido! Tu asistencia ha sido registrada.")
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model NotificacionAsistencia {
  id                String   @id @default(uuid())
  estudianteId      String
  estudiante        Estudiante @relation(fields: [estudianteId], references: [id])
  
  asistenciaId      String?  // Referencia a la asistencia (si aplica)
  
  tipo              String   // RETARDO, AUSENCIA, ENTRADA, GENERAL
  canal             String   // EMAIL_PADRE, EMAIL_MADRE, TELEGRAM_PADRE, TELEGRAM_MADRE, TELEGRAM_GRUPO
  
  destino           String   // Email o chat ID
  asunto            String?
  mensaje           String
  
  enviado           Boolean  @default(false)
  error             String?
  fechaEnvio        DateTime?
  
  createdAt         DateTime @default(now())
  
  @@index([estudianteId])
  @@index([tipo])
}
