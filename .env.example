# ─────────────────────────────────────────────────────────────
# BASE DE DATOS - Neon PostgreSQL (Requerido)
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://usuario:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://usuario:password@host/dbname?sslmode=require"

# ─────────────────────────────────────────────────────────────
# NOTIFICACIONES POR EMAIL - Resend (Opcional)
# ─────────────────────────────────────────────────────────────
# Obtén tu API Key en: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# ─────────────────────────────────────────────────────────────
# NOTA: El Bot Token de Telegram NO va en variables de entorno
# Se configura desde la interfaz del sistema en Config > Telegram
